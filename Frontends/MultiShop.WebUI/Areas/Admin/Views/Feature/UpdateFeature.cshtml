@model UpdateFeatureDto
@{
    ViewData["Title"] = "UpdateFeature";
    Layout = "~/Areas/Admin/Views/AdminLayout/Index.cshtml";
}

<section class="content container-fluid">
    <div class="row">
        <div class="col-md-12">
            <div class="chart-box">
                <h4>Öne Çıkanlar Güncelleme Sayfası</h4>
                <br />
                <div class="bs-example" data-example-id="bordered-table">

                    <form method="post">
                        <input type="hidden" asp-for="FeatureId" />
                        <label>Öne Çıkanlar Başlığı</label>
                        <input type="text" class="form-control" asp-for="Title" />
                        <br />
                        <label>Öne Çıkanlar Icon</label>
                        <input type="text" class="form-control" asp-for="Icon" />
                        <br />
                        <button type="submit" class="btn btn-primary">Öne Çıkanları Güncelle</button>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

